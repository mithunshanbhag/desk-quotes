<Project Sdk="WixToolset.Sdk/6.0.2">

  <PropertyGroup>
    <OutputType>Package</OutputType>
    <InstallerPlatform>x64</InstallerPlatform>
    <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == ''">win-x64</RuntimeIdentifier>
    <SelfContained Condition="'$(SelfContained)' == ''">false</SelfContained>
    <DeskQuotesProjectPath>..\DeskQuotes\DeskQuotes.csproj</DeskQuotesProjectPath>
    <DeskQuotesPublishDir>$([MSBuild]::NormalizeDirectory('$(MSBuildProjectDirectory)', 'obj', '$(Configuration)', 'publish'))</DeskQuotesPublishDir>
    <DefineConstants>$(DefineConstants);ProductName=DeskQuotes;DeskQuotesPublishDir=$(DeskQuotesPublishDir)</DefineConstants>
  </PropertyGroup>

  <Target Name="PublishDeskQuotes" BeforeTargets="Build">
    <MSBuild
      Projects="$(DeskQuotesProjectPath)"
      Targets="Publish"
      Properties="Configuration=$(Configuration);RuntimeIdentifier=$(RuntimeIdentifier);SelfContained=$(SelfContained);PublishDir=$(DeskQuotesPublishDir);EnableWindowsTargeting=true" />
  </Target>

</Project>
